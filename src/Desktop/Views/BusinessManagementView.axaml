<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Desktop.ViewModels"
             x:Class="Desktop.Views.BusinessManagementView"
             x:DataType="vm:BusinessManagementViewModel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Classes="card" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Business Management" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="🔄 Refresh"
                        Command="{Binding LoadBusinessesCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="2"
                        Content="➕ Add Business"
                        Command="{Binding OpenCreateBusinessDialogCommand}"
                        IsEnabled="{Binding CanManageBusinesses}"
                        Classes="accent"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="3"
                        Content="🏪 Add Shop"
                        Command="{Binding OpenCreateShopDialogCommand}"
                        IsEnabled="{Binding SelectedBusiness, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Businesses List -->
            <Border Grid.Column="0" Classes="card" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Businesses" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Businesses}"
                              SelectedItem="{Binding SelectedBusiness}"
                              AutoGenerateColumns="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="120"/>
                            <DataGridTemplateColumn Header="Actions" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑️"
                                                Command="{Binding $parent[UserControl].((vm:BusinessManagementViewModel)DataContext).DeleteBusinessCommand}"
                                                CommandParameter="{Binding}"
                                                Classes="danger"
                                                ToolTip.Tip="Delete business"
                                                Padding="6,3"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Shops List -->
            <Border Grid.Column="1" Classes="card" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding SelectedBusiness.Name, StringFormat='Shops — {0}', FallbackValue='Shops'}"
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Shops}"
                              SelectedItem="{Binding SelectedShop}"
                              AutoGenerateColumns="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTemplateColumn Header="Actions" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑️"
                                                Command="{Binding $parent[UserControl].((vm:BusinessManagementViewModel)DataContext).DeleteShopCommand}"
                                                CommandParameter="{Binding}"
                                                Classes="danger"
                                                ToolTip.Tip="Delete shop"
                                                Padding="6,3"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Create Business / Shop Form -->
            <Border Grid.Column="2" Classes="card" IsVisible="{Binding IsCreateBusinessDialogOpen}">
                <ScrollViewer>
                    <StackPanel Spacing="12">
                        <TextBlock Text="Create Business" FontWeight="Bold" FontSize="16"/>

                        <StackPanel>
                            <TextBlock Text="Business Name *" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewBusinessName}" Watermark="Enter business name"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Type" FontWeight="Bold" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding BusinessTypes}"
                                      SelectedItem="{Binding NewBusinessType}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Description" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewBusinessDescription}" Watermark="Optional description"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Address" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewBusinessAddress}" Watermark="Business address"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Phone" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewBusinessPhone}" Watermark="Phone number"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Email" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewBusinessEmail}" Watermark="Email address"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Tax ID" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewBusinessTaxId}" Watermark="Tax registration number"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <Button Content="Create Business"
                                    Command="{Binding CreateBusinessCommand}"
                                    IsEnabled="{Binding !IsLoading}"
                                    Classes="accent"
                                    HorizontalAlignment="Stretch"/>
                            <Button Content="Cancel"
                                    Command="{Binding CloseCreateBusinessDialogCommand}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="Red"
                                   IsVisible="{Binding HasError}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Classes="card" IsVisible="{Binding IsCreateShopDialogOpen}">
                <ScrollViewer>
                    <StackPanel Spacing="12">
                        <TextBlock Text="Create Shop" FontWeight="Bold" FontSize="16"/>

                        <StackPanel>
                            <TextBlock Text="Shop Name *" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewShopName}" Watermark="Enter shop name"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Address" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewShopAddress}" Watermark="Shop address"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Phone" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewShopPhone}" Watermark="Phone number"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Email" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewShopEmail}" Watermark="Email address"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <Button Content="Create Shop"
                                    Command="{Binding CreateShopCommand}"
                                    IsEnabled="{Binding !IsLoading}"
                                    Classes="accent"
                                    HorizontalAlignment="Stretch"/>
                            <Button Content="Cancel"
                                    Command="{Binding CloseCreateShopDialogCommand}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="Red"
                                   IsVisible="{Binding HasError}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Placeholder -->
            <Border Grid.Column="2" Classes="card"
                    IsVisible="{Binding !IsCreateBusinessDialogOpen}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                            IsVisible="{Binding !IsCreateShopDialogOpen}">
                    <TextBlock Text="Select a business to view its shops"
                               FontSize="13" Opacity="0.7" HorizontalAlignment="Center" TextAlignment="Center"/>
                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="Green"
                               IsVisible="{Binding SuccessMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="Red"
                               IsVisible="{Binding HasError}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="2"
                Background="#80000000"
                IsVisible="{Binding IsLoading}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressBar IsIndeterminate="True" Width="200"/>
                <TextBlock Text="Loading..." Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
