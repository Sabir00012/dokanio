<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Desktop.ViewModels"
             x:Class="Desktop.Views.AdvancedReportsView"
             x:DataType="vm:AdvancedReportsViewModel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filters Bar -->
        <Border Grid.Row="0" Classes="card" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding Businesses}"
                          SelectedItem="{Binding SelectedBusiness}"
                          DisplayMemberBinding="{Binding Name}"
                          PlaceholderText="Select Business"
                          HorizontalAlignment="Stretch"
                          Margin="0,0,8,0"/>

                <DatePicker Grid.Column="1"
                            SelectedDate="{Binding StartDate}"
                            Margin="0,0,8,0"/>

                <DatePicker Grid.Column="2"
                            SelectedDate="{Binding EndDate}"
                            Margin="0,0,8,0"/>

                <Button Grid.Column="3"
                        Content="📊 Generate"
                        Command="{Binding GenerateReportsCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        Classes="accent"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="4"
                        Content="📥 Export CSV"
                        Command="{Binding ExportReportCommand}"
                        CommandParameter="Csv"
                        IsEnabled="{Binding DashboardOverview, Converter={x:Static ObjectConverters.IsNotNull}}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="5"
                        Content="🔄 Refresh"
                        Command="{Binding RefreshDataCommand}"
                        IsEnabled="{Binding !IsLoading}"/>
            </Grid>
        </Border>

        <!-- Summary Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Classes="card" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="Revenue" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text="{Binding TotalRevenue, StringFormat='৳{0:N0}'}"
                               FontSize="20" FontWeight="Bold" Foreground="#4CAF50"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="card" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="Transactions" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text="{Binding TotalTransactions}"
                               FontSize="20" FontWeight="Bold" Foreground="#2196F3"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Classes="card" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="Avg Order" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text="{Binding AverageOrderValue, StringFormat='৳{0:N0}'}"
                               FontSize="20" FontWeight="Bold" Foreground="#FF9800"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Classes="card" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="Est. Profit" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text="{Binding EstimatedProfit, StringFormat='৳{0:N0}'}"
                               FontSize="20" FontWeight="Bold" Foreground="#9C27B0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Classes="card" Margin="5,0">
                <StackPanel>
                    <TextBlock Text="Low Stock" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text="{Binding LowStockAlerts}"
                               FontSize="20" FontWeight="Bold" Foreground="#FF5722"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="5" Classes="card" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="Expiry Alerts" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text="{Binding ExpiryAlerts}"
                               FontSize="20" FontWeight="Bold" Foreground="#F44336"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Report Tabs -->
        <TabControl Grid.Row="2">
            <!-- Daily Revenue -->
            <TabItem Header="Daily Revenue">
                <Border Classes="card">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Daily Revenue Breakdown" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding DailyRevenueData}"
                                  AutoGenerateColumns="False"
                                  CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='dd/MM/yyyy'}" Width="120"/>
                                <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat='৳{0:N2}'}" Width="150"/>
                                <DataGridTextColumn Header="Transactions" Binding="{Binding TransactionCount}" Width="120"/>
                                <DataGridTextColumn Header="Avg Order" Binding="{Binding AverageOrderValue, StringFormat='৳{0:N2}'}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Top Products -->
            <TabItem Header="Top Products">
                <Border Classes="card">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Top Selling Products" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding TopProducts}"
                                  AutoGenerateColumns="False"
                                  CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Qty Sold" Binding="{Binding QuantitySold}" Width="100"/>
                                <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat='৳{0:N2}'}" Width="150"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Shop Performance -->
            <TabItem Header="Shop Performance">
                <Border Classes="card">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Shop Performance Comparison" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding ShopPerformances}"
                                  AutoGenerateColumns="False"
                                  CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Shop" Binding="{Binding ShopName}" Width="*"/>
                                <DataGridTextColumn Header="Revenue" Binding="{Binding TodayRevenue, StringFormat='৳{0:N2}'}" Width="150"/>
                                <DataGridTextColumn Header="Transactions" Binding="{Binding TodayTransactions}" Width="120"/>
                                <DataGridTextColumn Header="Avg Order" Binding="{Binding AverageOrderValue, StringFormat='৳{0:N2}'}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Profit Analysis -->
            <TabItem Header="Profit by Category">
                <Border Classes="card">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Profit by Category" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding CategoryProfits}"
                                  AutoGenerateColumns="False"
                                  CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="*"/>
                                <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat='৳{0:N2}'}" Width="150"/>
                                <DataGridTextColumn Header="Cost" Binding="{Binding EstimatedCost, StringFormat='৳{0:N2}'}" Width="150"/>
                                <DataGridTextColumn Header="Profit" Binding="{Binding EstimatedProfit, StringFormat='৳{0:N2}'}" Width="150"/>
                                <DataGridTextColumn Header="Margin %" Binding="{Binding ProfitMarginPercentage, StringFormat='{}{0:N1}%'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Alerts -->
            <TabItem Header="Alerts">
                <Border Classes="card">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Active Alerts" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Alerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFF3E0" Padding="12" Margin="0,0,0,6" CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text="{Binding Message}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Error / Status -->
        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   IsVisible="{Binding HasError}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,4"/>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="3"
                Background="#80000000"
                IsVisible="{Binding IsLoading}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <ProgressBar IsIndeterminate="True" Width="200"/>
                <TextBlock Text="Generating reports..." Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
